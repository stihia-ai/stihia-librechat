# =============================================================================
# Stihia + LibreChat  —  Environment Variables
# =============================================================================
# Copy this file to .env, then set the provider keys you want to use.

# -- Stihia ------------------------------------------------------------------
# Required — your Stihia API key
STIHIA_API_KEY=
# Optional — Stihia project key (default: "librechat")
STIHIA_PROJECT_KEY=librechat
# Optional — Stihia API base URL
# STIHIA_API_URL=https://api.stihia.ai
# Optional — send full conversation history to Stihia instead of only the
# system prompt and latest message (default: true)
# STIHIA_SEND_FULL_HISTORY=true

# -- LLM Provider Keys -------------------------------------------------------
# Add the keys for the providers you want to use. These are passed directly
# to the provider APIs via the proxy and are NEVER sent to Stihia.

# OpenAI API key
OPENAI_API_KEY=

# -- LibreChat Auth & Encryption ---------------------------------------------
# Optional for local onboarding: if any value is blank, Docker Compose startup
# auto-generates it for that container run.
#
# For stable sessions across restarts (and always for production), set these
# explicitly with strong unique values.

# 32-byte hex key (64 chars) for credential encryption
CREDS_KEY=
# 16-byte hex IV (32 chars) for credential encryption
CREDS_IV=
# 32-byte hex key (64 chars) for signing access tokens
JWT_SECRET=
# 32-byte hex key (64 chars) for signing refresh tokens
JWT_REFRESH_SECRET=

# -- LibreChat ----------------------------------------------------------------
# See https://www.librechat.ai/docs/configuration/dotenv for all options.
# The values below are sensible defaults for a local Docker setup.

ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# -- RAG PostgreSQL -----------------------------------------------------------
# Optional for local onboarding: compose defaults are used when these are empty.
#
# For production, set all values explicitly with strong unique credentials.
# If a password contains '$', escape each '$' as '$$' in this file because
# Docker Compose performs variable interpolation when reading .env values.

# Defaults to librechat_rag
LIBRECHAT_RAG_POSTGRES_DB=
# Defaults to librechat
LIBRECHAT_RAG_POSTGRES_USER=
# Defaults to librechat_dev_password_change_me
LIBRECHAT_RAG_POSTGRES_PASSWORD=
# LIBRECHAT_RAG_POSTGRES_PORT=5432
