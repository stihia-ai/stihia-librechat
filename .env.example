# =============================================================================
# Stihia + LibreChat  —  Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys before running docker compose up.

# -- Stihia ------------------------------------------------------------------
STIHIA_API_KEY=             # Required — your Stihia API key
STIHIA_PROJECT_KEY=librechat  # Optional — Stihia project key (default: "librechat")
# STIHIA_API_URL=https://api.stihia.ai  # Optional — Stihia API base URL

# -- LLM Provider Keys -------------------------------------------------------
# Add the keys for the providers you want to use. These are passed directly
# to the provider APIs via the proxy and are NEVER sent to Stihia.

OPENAI_API_KEY=             # OpenAI API key
ANTHROPIC_API_KEY=          # Anthropic API key
GOOGLE_GEMINI_API_KEY=      # Google Gemini API key

# -- LibreChat Auth & Encryption -----------------------------------------------
# REQUIRED — LibreChat will not start without these.
# Generate secure values at https://www.librechat.ai/toolkit/creds_generator

CREDS_KEY=                  # Required — 32-byte hex key (64 chars) for credential encryption
CREDS_IV=                   # Required — 16-byte hex IV (32 chars) for credential encryption
JWT_SECRET=                 # Required — 32-byte hex key (64 chars) for signing access tokens
JWT_REFRESH_SECRET=         # Required — 32-byte hex key (64 chars) for signing refresh tokens

# -- LibreChat ----------------------------------------------------------------
# See https://www.librechat.ai/docs/configuration/dotenv for all options.
# The values below are sensible defaults for a local Docker setup.

ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# -- RAG PostgreSQL -----------------------------------------------------------
# Required for the pgvector database used by LibreChat's RAG API.
# Use production-grade values. Do not reuse defaults across environments.
# If a password contains '$', escape each '$' as '$$' in this file because
# Docker Compose performs variable interpolation when reading .env values.

LIBRECHAT_RAG_POSTGRES_DB=replace-with-rag-database-name
LIBRECHAT_RAG_POSTGRES_USER=replace-with-rag-database-user
LIBRECHAT_RAG_POSTGRES_PASSWORD=replace-with-a-long-random-secret
# LIBRECHAT_RAG_POSTGRES_PORT=5432
